<!doctype html>
<html {% if section %} data-current="{{ section }}"{% endif %} lang="en">

{% include "components/head.njk" %}

{% block header %}
<body class="internal {{ class }} " >
{% include "components/header.njk" %}
{% include "components/off-canvas.njk" %}
{% endblock %}
  {% block hero %}




<section class="sliderbox hide-for-print">
<div class="home-slide hide-for-print">

  <div class="slide-wrap">
 {% if entry.url == "/about-us/" %}
  <div class="internalhero" style="background-image: url(/static/img/hero/about-1.jpg);"></div>
  {% elif entry.url == "/services/" %}
  <div class="internalhero" style="background-image: url(/static/img/hero/services-1.jpg);"></div>
{% elif entry.url == "/contact/" %}
  <div class="internalhero" style="background-image: url(/static/img/hero/contact-1.jpg);"></div>
{% else %}
  <div class="internalhero" style="background-image: url(/static/img/hero/home-1.jpg);"></div>
{% endif %}
    <div class="dot-overlay"></div>
     <div class="flex-caption centre">
      <h1>{{ title}}</h1>
      <div class="flextext"><p>{{ content | safe }}</p></div>
    </div>
  </div>

  



</div>
</section>





  {% endblock %}





{% include "components/javascript.njk" %}

</body>
</html>
